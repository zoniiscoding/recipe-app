MONGO_URI=mongodb://127.0.0.1:27017/recipeDB
PORT=5001
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000

# Paste full JSON from Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT=

# Local dev without Firebase service account (never use in production)
DEV_AUTH_BYPASS=true

# Skip local MongoDB and use in-memory DB (optional)
# USE_MEMORY_DB=true

# Optional: MongoDB Atlas (cloud) — replace MONGO_URI with your Atlas connection string
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/recipeDB?retryWrites=true&w=majority
